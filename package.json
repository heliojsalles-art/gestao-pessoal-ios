{
  "name": "gestao-pessoal-ios",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cap:init": "npx cap init \"Gestão Pessoal\" \"com.helio.gestaopessoal\" --web-dir dist",
    "cap:sync": "npx cap sync ios",
    "ios": "npx cap open ios",
    "cap:add:ios": "npx cap add ios",
    "cap:copy": "npx cap copy ios",
    "codemagic:prepare:ios": "npm run build && (test -d ios/App/App.xcworkspace || npm run cap:add:ios) && npm run assets:generate:ios && npm run cap:sync",
    "assets:generate:ios": "npx capacitor-assets generate --ios"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "7.0.2",
    "@capacitor/core": "7.6.0",
    "@capacitor/filesystem": "7.0.0",
    "@capacitor/ios": "7.6.0",
    "@capacitor/share": "7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.3",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "@capacitor/cli": "7.6.0",
    "@capacitor/assets": "3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
